# ── Dataset ────────────────────────────────────────────────────────────────────
dataset/
archive/
archive.zip
results/

# ── Archives ───────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tar

# ── Model checkpoints ──────────────────────────────────────────────────────────
checkpoints/

# ── TensorBoard logs (binary event files) ─────────────────────────────────────
logs/*/
# Allow human-readable training logs and metrics CSVs
!logs/*.txt
!logs/*.csv

# ── Python virtual environment ─────────────────────────────────────────────────
venv/

# ── Python cache ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Model weights / large binaries ────────────────────────────────────────────
*.pth
*.pt
*.onnx
*.bin
*.safetensors

# ── HuggingFace / torch cache ─────────────────────────────────────────────────
.cache/

# ── Project-specific exclusions ───────────────────────────────────────────────
NNDL Report.pdf

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
